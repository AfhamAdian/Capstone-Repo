{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/apps/api/src/server.js",
  "scripts": {
    "dev": "tsx watch apps/api/src/server.ts",
    "build": "tsc -p tsconfig.json",
    "postbuild": "tsc-alias -p tsconfig.json",
    "start": "node dist/apps/api/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:github-metrics": "npm run build && node dist/scripts/test-github-metrics.js"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.0",
    "@supabase/supabase-js": "^2.101.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
